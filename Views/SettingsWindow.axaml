<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ellabi.ViewModels"
        xmlns:local="clr-namespace:ellabi"
        x:Class="ellabi.Views.SettingsWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Settings — Move Mouse"
        Width="680" Height="500"
        Background="#181A1F"
        CanResize="False"
        WindowStartupLocation="CenterOwner">

    <Window.Styles>
        <Style Selector="TabControl">
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="TabItem">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style Selector="TabItem:selected /template/ Border#PART_SelectedPipe">
            <Setter Property="IsVisible" Value="False" />
        </Style>
        <Style Selector="TabItem:selected">
            <Setter Property="Foreground" Value="#89B4FA" />
        </Style>
        <Style Selector="ToggleSwitch">
            <Setter Property="OnContent" Value=""/>
            <Setter Property="OffContent" Value=""/>
            <Setter Property="Margin" Value="0,4,10,4"/>
        </Style>
        <Style Selector="TextBlock.ToggleLabel">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,0"/>
        </Style>
        <Style Selector="Border.TabContent">
            <Setter Property="BorderBrush" Value="#4582c4"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Margin" Value="10,10,20,10"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="CornerRadius" Value="0" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="*,60">
        <TabControl Grid.Row="0" TabStripPlacement="Right" Margin="0,10,10,0">
            <TabItem Header="Actions">
                <Border Classes="TabContent">
                    <Grid ColumnDefinitions="200,*" DataContext="{Binding Settings}">
                        <!-- Left Panel -->
                        <Border Grid.Column="0" BorderBrush="#333" BorderThickness="0,0,1,0" Margin="0,0,15,0" Padding="0,0,15,0">
                            <ListBox x:Name="ActionsList" ItemsSource="{Binding Actions}" SelectedIndex="0" Background="Transparent" Foreground="White">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}" Foreground="White" Padding="5"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                        
                        <!-- Right Panel -->
                        <StackPanel Grid.Column="1" DataContext="{Binding #ActionsList.SelectedItem}" x:CompileBindings="False">
                            <Grid ColumnDefinitions="100,*" Margin="0,0,0,10">
                                <TextBlock Text="Name" Foreground="White" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding Name}" Background="#222" Foreground="White"/>
                            </Grid>
                            
                            <Grid ColumnDefinitions="100,*" Margin="0,0,0,10">
                                <TextBlock Text="Random" Foreground="White" VerticalAlignment="Center"/>
                                <ToggleSwitch Grid.Column="1" IsChecked="{Binding Random}"/>
                            </Grid>
                            
                            <Grid ColumnDefinitions="100,*" Margin="0,0,0,10">
                                <TextBlock Text="Distance" Foreground="White" VerticalAlignment="Center"/>
                                <NumericUpDown Grid.Column="1" Value="{Binding Distance}" Minimum="1" Maximum="2000" FormatString="0" HorizontalAlignment="Left" Width="100"/>
                            </Grid>

                            <Grid ColumnDefinitions="100,*" Margin="0,0,0,10">
                                <TextBlock Text="Direction" Foreground="White" VerticalAlignment="Center"/>
                                <ComboBox Grid.Column="1" ItemsSource="{Binding CursorDirectionValues}" SelectedItem="{Binding Direction}" HorizontalAlignment="Left" Width="150" Background="#222" Foreground="White"/>
                            </Grid>

                            <Grid ColumnDefinitions="100,*" Margin="0,0,0,10">
                                <TextBlock Text="Abortable" Foreground="White" VerticalAlignment="Center"/>
                                <ToggleSwitch Grid.Column="1" IsChecked="{Binding AbortIfUserActivityDetected}"/>
                            </Grid>

                            <Grid ColumnDefinitions="100,*" Margin="0,0,0,10">
                                <TextBlock Text="Speed" Foreground="White" VerticalAlignment="Center"/>
                                <ComboBox Grid.Column="1" ItemsSource="{Binding CursorSpeedValues}" SelectedItem="{Binding Speed}" HorizontalAlignment="Left" Width="150" Background="#222" Foreground="White"/>
                            </Grid>
                            
                            <Grid ColumnDefinitions="100,*" Margin="0,0,0,10">
                                <TextBlock Text="Trigger" Foreground="White" VerticalAlignment="Center"/>
                                <ComboBox Grid.Column="1" ItemsSource="{Binding EventTriggerValues}" SelectedItem="{Binding Trigger}" HorizontalAlignment="Left" Width="150" Background="#222" Foreground="White"/>
                            </Grid>
                            
                            <Grid ColumnDefinitions="100,Auto,Auto" Margin="0,0,0,10">
                                <TextBlock Text="Repeat" Foreground="White" VerticalAlignment="Center"/>
                                <ToggleSwitch Grid.Column="1" IsChecked="{Binding Repeat}" Margin="0,0,10,0"/>
                                <ComboBox Grid.Column="2" ItemsSource="{Binding IntervalRepeatModeValues}" SelectedItem="{Binding RepeatMode}" HorizontalAlignment="Left" Width="120" Background="#222" Foreground="White"/>
                            </Grid>
                            
                            <Grid ColumnDefinitions="100,*" Margin="0,0,0,10">
                                <TextBlock Text="Enabled" Foreground="White" VerticalAlignment="Center"/>
                                <ToggleSwitch Grid.Column="1" IsChecked="{Binding IsEnabled}"/>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>
            </TabItem>
            
            <TabItem Header="Behaviour">
                <Border Classes="TabContent">
                    <StackPanel>
                        <Grid ColumnDefinitions="Auto,*" Margin="0,0,0,15">
                            <TextBlock Text="Repeat actions every" VerticalAlignment="Center" Foreground="White" Margin="0,0,10,0"/>
                            <NumericUpDown Grid.Column="1" Value="{Binding Settings.LowerInterval}" Minimum="1" Maximum="3600" FormatString="0" Width="100" HorizontalAlignment="Left"/>
                            <TextBlock Grid.Column="1" Text="seconds" VerticalAlignment="Center" Foreground="White" Margin="110,0,0,0"/>
                        </Grid>
                        
                        <Grid ColumnDefinitions="Auto,*">
                            <ToggleSwitch IsChecked="{Binding Settings.AutoPause}" />
                            <TextBlock Grid.Column="1" Classes="ToggleLabel" Text="Automatically stop when user activity detected"/>
                        </Grid>
                        
                        <Grid ColumnDefinitions="Auto,*">
                            <ToggleSwitch IsChecked="{Binding Settings.LaunchAtLogon}" />
                            <TextBlock Grid.Column="1" Classes="ToggleLabel" Text="Launch Move Mouse at start-up"/>
                        </Grid>
                        
                        <Grid ColumnDefinitions="Auto,*">
                            <ToggleSwitch IsChecked="{Binding Settings.StartAtLaunch}" />
                            <TextBlock Grid.Column="1" Classes="ToggleLabel" Text="Start actions when Move Mouse is launched"/>
                        </Grid>
                        
                        <Grid ColumnDefinitions="Auto,*">
                            <ToggleSwitch IsChecked="{Binding Settings.PauseOnBattery}" />
                            <TextBlock Grid.Column="1" Classes="ToggleLabel" Text="Pause when running on battery"/>
                        </Grid>
                        
                        <Grid ColumnDefinitions="Auto,*">
                            <ToggleSwitch IsChecked="{Binding Settings.EnableLogging}" />
                            <TextBlock Grid.Column="1" Classes="ToggleLabel" Text="Enable logging"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </TabItem>
            
            <TabItem Header="Appearance">
                <Border Classes="TabContent">
                    <StackPanel>
                        <Grid ColumnDefinitions="Auto,*">
                            <ToggleSwitch IsChecked="{Binding Settings.HideMainWindow}" />
                            <TextBlock Grid.Column="1" Classes="ToggleLabel" Text="Hide Move Mouse window"/>
                        </Grid>
                        
                        <Grid ColumnDefinitions="Auto,*">
                            <ToggleSwitch IsChecked="{Binding Settings.TopmostWhenRunning}" />
                            <TextBlock Grid.Column="1" Classes="ToggleLabel" Text="Show topmost when running"/>
                        </Grid>
                        
                        <Grid ColumnDefinitions="Auto,*">
                            <ToggleSwitch IsChecked="{Binding Settings.MinimiseOnStop}" />
                            <TextBlock Grid.Column="1" Classes="ToggleLabel" Text="Minimise when not running"/>
                        </Grid>
                        
                        <Grid ColumnDefinitions="Auto,*">
                            <ToggleSwitch IsChecked="{Binding Settings.HideFromTaskbar}" />
                            <TextBlock Grid.Column="1" Classes="ToggleLabel" Text="Hide from taskbar"/>
                        </Grid>
                        
                        <Grid ColumnDefinitions="Auto,*">
                            <ToggleSwitch IsChecked="{Binding Settings.ShowTaskbarStatus}" />
                            <TextBlock Grid.Column="1" Classes="ToggleLabel" Text="Show status on taskbar"/>
                        </Grid>
                        
                        <Grid ColumnDefinitions="Auto,*">
                            <ToggleSwitch IsChecked="{Binding Settings.HideSystemTrayIcon}" />
                            <TextBlock Grid.Column="1" Classes="ToggleLabel" Text="Hide system tray icon"/>
                        </Grid>
                        
                        <Grid ColumnDefinitions="Auto,*">
                            <ToggleSwitch IsChecked="{Binding Settings.ShowSystemTrayNotifications}" />
                            <TextBlock Grid.Column="1" Classes="ToggleLabel" Text="Show system tray notifications"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </TabItem>

            <TabItem Header="Schedules">
                <Border Classes="TabContent">
                    <TextBlock Text="Schedule configuration is available in full release!" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Border>
            </TabItem>

            <TabItem Header="Blackouts">
                <Border Classes="TabContent">
                    <TextBlock Text="Blackout configuration is available in full release!" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Border>
            </TabItem>

            <TabItem Header="About">
                <Border Classes="TabContent">
                    <StackPanel Spacing="10" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Move Mouse for Linux" Foreground="White" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="Powered by .NET 8 + Avalonia UI" Foreground="White" HorizontalAlignment="Center"/>
                        <Button Content="View on GitHub" Click="OnGitHubClick" Background="#4582c4" Foreground="White" Margin="0,10,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </TabItem>
        </TabControl>
        
        <Border Grid.Row="1" Background="#11151c" Padding="0,0,20,0">
            <Button Content="Close" 
                    HorizontalAlignment="Right" 
                    VerticalAlignment="Center"
                    Width="80" HorizontalContentAlignment="Center"
                    Background="#333" Foreground="White"
                    Command="{Binding SaveSettingsCommand}"
                    Click="OnCloseClick" />
        </Border>
    </Grid>
</Window>

<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ellabi.ViewModels"
        xmlns:actions="clr-namespace:ellabi.Actions"
        xmlns:schedules="clr-namespace:ellabi.Schedules"
        xmlns:classes="clr-namespace:ellabi.Classes"
        xmlns:local="clr-namespace:ellabi"
        x:Class="ellabi.Views.SettingsWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Settings — Move Mouse"
        Width="680" Height="500"
        Background="#181A1F"
        CanResize="False"
        WindowStartupLocation="CenterOwner">

    <Window.Styles>
        <Style Selector="TabControl">
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="TabItem">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style Selector="TabItem:selected /template/ Border#PART_SelectedPipe">
            <Setter Property="IsVisible" Value="False" />
        </Style>
        <Style Selector="TabItem:selected">
            <Setter Property="Foreground" Value="#89B4FA" />
        </Style>
        <Style Selector="ToggleSwitch">
            <Setter Property="OnContent" Value=""/>
            <Setter Property="OffContent" Value=""/>
            <Setter Property="Margin" Value="0,4,10,4"/>
        </Style>
        <Style Selector="TextBlock.ToggleLabel">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,0"/>
        </Style>
        <Style Selector="Border.TabContent">
            <Setter Property="BorderBrush" Value="#4582c4"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Margin" Value="10,10,20,10"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="CornerRadius" Value="0" />
        </Style>
        <!-- Shared editor field styles (Actions / Schedules / Blackouts) -->
        <Style Selector="TextBlock.FieldLabel">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="ComboBox.Field">
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Width" Value="180"/>
            <Setter Property="Background" Value="#222"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="TextBox.Field">
            <Setter Property="Background" Value="#222"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Grid.Row">
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style Selector="CheckBox.Day">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="*,60">
        <TabControl Grid.Row="0" TabStripPlacement="Right" Margin="0,10,10,0">
            <TabItem Header="Actions">
                <Border Classes="TabContent">
                    <Grid ColumnDefinitions="220,*" x:CompileBindings="False">
                        <Grid.Styles>
                            <Style Selector="TextBlock.FieldLabel">
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                            <Style Selector="ComboBox.Field">
                                <Setter Property="HorizontalAlignment" Value="Left"/>
                                <Setter Property="Width" Value="180"/>
                                <Setter Property="Background" Value="#222"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Style>
                            <Style Selector="TextBox.Field">
                                <Setter Property="Background" Value="#222"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Style>
                            <Style Selector="Grid.Row">
                                <Setter Property="Margin" Value="0,0,0,8"/>
                            </Style>
                        </Grid.Styles>

                        <!-- Left: action list + add/remove -->
                        <Grid Grid.Column="0" RowDefinitions="*,Auto" Margin="0,0,15,0">
                            <Border Grid.Row="0" BorderBrush="#333" BorderThickness="0,0,1,0" Padding="0,0,15,0">
                                <ListBox x:Name="ActionsList" ItemsSource="{Binding Actions}"
                                         SelectedItem="{Binding SelectedAction}"
                                         Background="Transparent" Foreground="White">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}" Foreground="White" Padding="5"/>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>
                            <StackPanel Grid.Row="1" Margin="0,8,15,0" Spacing="6">
                                <ComboBox HorizontalAlignment="Stretch" ItemsSource="{Binding ActionTypeNames}"
                                          SelectedItem="{Binding SelectedActionTypeName}"
                                          Background="#222" Foreground="White"/>
                                <Grid ColumnDefinitions="*,*">
                                    <Button Grid.Column="0" Content="Add" Command="{Binding AddActionCommand}"
                                            Margin="0,0,4,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                            Background="#4582c4" Foreground="White"/>
                                    <Button Grid.Column="1" Content="Remove" Command="{Binding RemoveActionCommand}"
                                            Margin="4,0,0,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                            Background="#5a3030" Foreground="White"/>
                                </Grid>
                            </StackPanel>
                        </Grid>

                        <!-- Right: editor for the selected action -->
                        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel DataContext="{Binding SelectedAction}">
                                <TextBlock Text="Select or add an action to edit it." Foreground="#888"
                                           IsVisible="{Binding $parent[ScrollViewer].DataContext, Converter={x:Static ObjectConverters.IsNull}}"/>

                                <!-- Common fields -->
                                <Grid Classes="Row" ColumnDefinitions="120,*">
                                    <TextBlock Classes="FieldLabel" Text="Name"/>
                                    <TextBox Grid.Column="1" Classes="Field" Text="{Binding Name}"/>
                                </Grid>
                                <Grid Classes="Row" ColumnDefinitions="120,*">
                                    <TextBlock Classes="FieldLabel" Text="Trigger"/>
                                    <ComboBox Grid.Column="1" Classes="Field" ItemsSource="{Binding EventTriggerValues}" SelectedItem="{Binding Trigger}"/>
                                </Grid>
                                <Grid Classes="Row" ColumnDefinitions="120,Auto,Auto">
                                    <TextBlock Classes="FieldLabel" Text="Repeat"/>
                                    <ToggleSwitch Grid.Column="1" IsChecked="{Binding Repeat}" Margin="0,0,10,0"/>
                                    <ComboBox Grid.Column="2" Classes="Field" Width="130" ItemsSource="{Binding IntervalRepeatModeValues}" SelectedItem="{Binding RepeatMode}"/>
                                </Grid>
                                <Grid Classes="Row" ColumnDefinitions="120,*">
                                    <TextBlock Classes="FieldLabel" Text="Enabled"/>
                                    <ToggleSwitch Grid.Column="1" IsChecked="{Binding IsEnabled}"/>
                                </Grid>

                                <Separator Background="#333" Margin="0,4,0,10"/>

                                <!-- Type-specific fields -->
                                <ContentControl Content="{Binding}">
                                    <ContentControl.DataTemplates>

                                        <DataTemplate DataType="actions:MoveMouseCursorAction">
                                            <StackPanel>
                                                <Grid Classes="Row" ColumnDefinitions="120,*"><TextBlock Classes="FieldLabel" Text="Distance"/><NumericUpDown Grid.Column="1" Value="{Binding Distance}" Minimum="1" Maximum="2000" FormatString="0" HorizontalAlignment="Left" Width="120"/></Grid>
                                                <Grid Classes="Row" ColumnDefinitions="120,*"><TextBlock Classes="FieldLabel" Text="Direction"/><ComboBox Grid.Column="1" Classes="Field" ItemsSource="{Binding CursorDirectionValues}" SelectedItem="{Binding Direction}"/></Grid>
                                                <Grid Classes="Row" ColumnDefinitions="120,*"><TextBlock Classes="FieldLabel" Text="Speed"/><ComboBox Grid.Column="1" Classes="Field" ItemsSource="{Binding CursorSpeedValues}" SelectedItem="{Binding Speed}"/></Grid>
                                                <Grid Classes="Row" ColumnDefinitions="120,*"><TextBlock Classes="FieldLabel" Text="Random"/><ToggleSwitch Grid.Column="1" IsChecked="{Binding Random}"/></Grid>
                                                <Grid Classes="Row" ColumnDefinitions="120,*"><TextBlock Classes="FieldLabel" Text="Max distance"/><NumericUpDown Grid.Column="1" Value="{Binding UpperDistance}" Minimum="1" Maximum="2000" FormatString="0" HorizontalAlignment="Left" Width="120"/></Grid>
                                                <Grid Classes="Row" ColumnDefinitions="120,*"><TextBlock Classes="FieldLabel" Text="Stop on activity"/><ToggleSwitch Grid.Column="1" IsChecked="{Binding AbortIfUserActivityDetected}"/></Grid>
                                            </StackPanel>
                                        </DataTemplate>

                                        <DataTemplate DataType="actions:ClickMouseAction">
                                            <StackPanel>
                                                <Grid Classes="Row" ColumnDefinitions="120,*"><TextBlock Classes="FieldLabel" Text="Button"/><ComboBox Grid.Column="1" Classes="Field" ItemsSource="{Binding MouseButtonValues}" SelectedItem="{Binding Button}"/></Grid>
                                                <Grid Classes="Row" ColumnDefinitions="120,*"><TextBlock Classes="FieldLabel" Text="Hold"/><ToggleSwitch Grid.Column="1" IsChecked="{Binding Hold}"/></Grid>
                                                <Grid Classes="Row" ColumnDefinitions="120,*"><TextBlock Classes="FieldLabel" Text="Hold seconds"/><NumericUpDown Grid.Column="1" Value="{Binding HoldInterval}" Minimum="0" Maximum="60" Increment="0.1" FormatString="0.0" HorizontalAlignment="Left" Width="120"/></Grid>
                                            </StackPanel>
                                        </DataTemplate>

                                        <DataTemplate DataType="actions:ScrollMouseAction">
                                            <StackPanel>
                                                <Grid Classes="Row" ColumnDefinitions="120,*"><TextBlock Classes="FieldLabel" Text="Direction"/><ComboBox Grid.Column="1" Classes="Field" ItemsSource="{Binding WheelDirectionValues}" SelectedItem="{Binding Direction}"/></Grid>
                                                <Grid Classes="Row" ColumnDefinitions="120,*"><TextBlock Classes="FieldLabel" Text="Amount"/><NumericUpDown Grid.Column="1" Value="{Binding Distance}" Minimum="1" Maximum="10000" FormatString="0" HorizontalAlignment="Left" Width="120"/></Grid>
                                                <Grid Classes="Row" ColumnDefinitions="120,*"><TextBlock Classes="FieldLabel" Text="Random"/><ToggleSwitch Grid.Column="1" IsChecked="{Binding Random}"/></Grid>
                                                <Grid Classes="Row" ColumnDefinitions="120,*"><TextBlock Classes="FieldLabel" Text="Max amount"/><NumericUpDown Grid.Column="1" Value="{Binding UpperDistance}" Minimum="1" Maximum="10000" FormatString="0" HorizontalAlignment="Left" Width="120"/></Grid>
                                                <TextBlock Text="120 units = one wheel notch. Emitted via a virtual uinput device." Foreground="#888" FontSize="11" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </DataTemplate>

                                        <DataTemplate DataType="actions:PositionMouseCursorAction">
                                            <StackPanel>
                                                <Grid Classes="Row" ColumnDefinitions="120,*"><TextBlock Classes="FieldLabel" Text="X"/><NumericUpDown Grid.Column="1" Value="{Binding X}" Minimum="0" Maximum="20000" FormatString="0" HorizontalAlignment="Left" Width="120"/></Grid>
                                                <Grid Classes="Row" ColumnDefinitions="120,*"><TextBlock Classes="FieldLabel" Text="Y"/><NumericUpDown Grid.Column="1" Value="{Binding Y}" Minimum="0" Maximum="20000" FormatString="0" HorizontalAlignment="Left" Width="120"/></Grid>
                                            </StackPanel>
                                        </DataTemplate>

                                        <DataTemplate DataType="actions:KeystrokeAction">
                                            <StackPanel>
                                                <Grid Classes="Row" ColumnDefinitions="120,*"><TextBlock Classes="FieldLabel" Text="Method"/><ComboBox Grid.Column="1" Classes="Field" ItemsSource="{Binding InputMethodValues}" SelectedItem="{Binding Method}"/></Grid>
                                                <Grid Classes="Row" ColumnDefinitions="120,*"><TextBlock Classes="FieldLabel" Text="Keys (VK)"/><TextBox Grid.Column="1" Classes="Field" Text="{Binding KeystrokesText}" Watermark="e.g. 17,65"/></Grid>
                                                <TextBlock Text="Comma-separated Windows virtual-key codes (17=Ctrl, 16=Shift, 65=A ...)." Foreground="#888" FontSize="11" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </DataTemplate>

                                        <DataTemplate DataType="actions:ActivateApplicationAction">
                                            <StackPanel>
                                                <Grid Classes="Row" ColumnDefinitions="120,*"><TextBlock Classes="FieldLabel" Text="Match by"/><ComboBox Grid.Column="1" Classes="Field" ItemsSource="{Binding SearchModeValues}" SelectedItem="{Binding Mode}"/></Grid>
                                                <Grid Classes="Row" ColumnDefinitions="120,*"><TextBlock Classes="FieldLabel" Text="Application"/><TextBox Grid.Column="1" Classes="Field" Text="{Binding Application}"/></Grid>
                                                <TextBlock Text="Matches caption/class/name. Uses KWin scripting (KDE Plasma)." Foreground="#888" FontSize="11" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </DataTemplate>

                                        <DataTemplate DataType="actions:CommandAction">
                                            <StackPanel>
                                                <Grid Classes="Row" ColumnDefinitions="120,*"><TextBlock Classes="FieldLabel" Text="File path"/><TextBox Grid.Column="1" Classes="Field" Text="{Binding FilePath}"/></Grid>
                                                <Grid Classes="Row" ColumnDefinitions="120,*"><TextBlock Classes="FieldLabel" Text="Arguments"/><TextBox Grid.Column="1" Classes="Field" Text="{Binding Arguments}"/></Grid>
                                                <Grid Classes="Row" ColumnDefinitions="120,*"><TextBlock Classes="FieldLabel" Text="Wait for exit"/><ToggleSwitch Grid.Column="1" IsChecked="{Binding WaitForExit}"/></Grid>
                                                <Grid Classes="Row" ColumnDefinitions="120,*"><TextBlock Classes="FieldLabel" Text="Hidden"/><ToggleSwitch Grid.Column="1" IsChecked="{Binding Hidden}"/></Grid>
                                            </StackPanel>
                                        </DataTemplate>

                                        <DataTemplate DataType="actions:ScriptAction">
                                            <StackPanel>
                                                <Grid Classes="Row" ColumnDefinitions="120,*"><TextBlock Classes="FieldLabel" Text="Script path"/><TextBox Grid.Column="1" Classes="Field" Text="{Binding ScriptPath}"/></Grid>
                                                <Grid Classes="Row" ColumnDefinitions="120,*"><TextBlock Classes="FieldLabel" Text="Wait for exit"/><ToggleSwitch Grid.Column="1" IsChecked="{Binding WaitForExit}"/></Grid>
                                                <Grid Classes="Row" ColumnDefinitions="120,*"><TextBlock Classes="FieldLabel" Text="Hidden"/><ToggleSwitch Grid.Column="1" IsChecked="{Binding Hidden}"/></Grid>
                                            </StackPanel>
                                        </DataTemplate>

                                        <DataTemplate DataType="actions:SleepAction">
                                            <StackPanel>
                                                <Grid Classes="Row" ColumnDefinitions="120,*"><TextBlock Classes="FieldLabel" Text="Seconds"/><NumericUpDown Grid.Column="1" Value="{Binding Seconds}" Minimum="0" Maximum="86400" Increment="0.5" FormatString="0.0" HorizontalAlignment="Left" Width="120"/></Grid>
                                                <Grid Classes="Row" ColumnDefinitions="120,*"><TextBlock Classes="FieldLabel" Text="Random"/><ToggleSwitch Grid.Column="1" IsChecked="{Binding Random}"/></Grid>
                                                <Grid Classes="Row" ColumnDefinitions="120,*"><TextBlock Classes="FieldLabel" Text="Max seconds"/><NumericUpDown Grid.Column="1" Value="{Binding UpperSeconds}" Minimum="0" Maximum="86400" Increment="0.5" FormatString="0.0" HorizontalAlignment="Left" Width="120"/></Grid>
                                            </StackPanel>
                                        </DataTemplate>

                                    </ContentControl.DataTemplates>
                                </ContentControl>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </TabItem>
            
            <TabItem Header="Behaviour">
                <Border Classes="TabContent">
                    <StackPanel>
                        <Grid ColumnDefinitions="Auto,*" Margin="0,0,0,15">
                            <TextBlock Text="Repeat actions every" VerticalAlignment="Center" Foreground="White" Margin="0,0,10,0"/>
                            <NumericUpDown Grid.Column="1" Value="{Binding Settings.LowerInterval}" Minimum="1" Maximum="3600" FormatString="0" Width="100" HorizontalAlignment="Left"/>
                            <TextBlock Grid.Column="1" Text="seconds" VerticalAlignment="Center" Foreground="White" Margin="110,0,0,0"/>
                        </Grid>
                        
                        <Grid ColumnDefinitions="Auto,*">
                            <ToggleSwitch IsChecked="{Binding Settings.AutoPause}" />
                            <TextBlock Grid.Column="1" Classes="ToggleLabel" Text="Automatically stop when user activity detected"/>
                        </Grid>
                        
                        <Grid ColumnDefinitions="Auto,*">
                            <ToggleSwitch IsChecked="{Binding Settings.LaunchAtLogon}" />
                            <TextBlock Grid.Column="1" Classes="ToggleLabel" Text="Launch Move Mouse at start-up"/>
                        </Grid>
                        
                        <Grid ColumnDefinitions="Auto,*">
                            <ToggleSwitch IsChecked="{Binding Settings.StartAtLaunch}" />
                            <TextBlock Grid.Column="1" Classes="ToggleLabel" Text="Start actions when Move Mouse is launched"/>
                        </Grid>
                        
                        <Grid ColumnDefinitions="Auto,*">
                            <ToggleSwitch IsChecked="{Binding Settings.PauseOnBattery}" />
                            <TextBlock Grid.Column="1" Classes="ToggleLabel" Text="Pause when running on battery"/>
                        </Grid>

                        <Grid ColumnDefinitions="Auto,*">
                            <ToggleSwitch IsChecked="{Binding Settings.StopWhenLocked}" />
                            <TextBlock Grid.Column="1" Classes="ToggleLabel" Text="Stop when the screen is locked"/>
                        </Grid>

                        <Grid ColumnDefinitions="Auto,*">
                            <ToggleSwitch IsChecked="{Binding Settings.EnableLogging}" />
                            <TextBlock Grid.Column="1" Classes="ToggleLabel" Text="Enable logging"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </TabItem>
            
            <TabItem Header="Appearance">
                <Border Classes="TabContent">
                    <StackPanel>
                        <Grid ColumnDefinitions="Auto,*">
                            <ToggleSwitch IsChecked="{Binding Settings.HideMainWindow}" />
                            <TextBlock Grid.Column="1" Classes="ToggleLabel" Text="Hide Move Mouse window"/>
                        </Grid>
                        
                        <Grid ColumnDefinitions="Auto,*">
                            <ToggleSwitch IsChecked="{Binding Settings.TopmostWhenRunning}" />
                            <TextBlock Grid.Column="1" Classes="ToggleLabel" Text="Show topmost when running"/>
                        </Grid>
                        
                        <Grid ColumnDefinitions="Auto,*">
                            <ToggleSwitch IsChecked="{Binding Settings.MinimiseOnStop}" />
                            <TextBlock Grid.Column="1" Classes="ToggleLabel" Text="Minimise when not running"/>
                        </Grid>
                        
                        <Grid ColumnDefinitions="Auto,*">
                            <ToggleSwitch IsChecked="{Binding Settings.HideFromTaskbar}" />
                            <TextBlock Grid.Column="1" Classes="ToggleLabel" Text="Hide from taskbar"/>
                        </Grid>
                        
                        <Grid ColumnDefinitions="Auto,*">
                            <ToggleSwitch IsChecked="{Binding Settings.ShowTaskbarStatus}" />
                            <TextBlock Grid.Column="1" Classes="ToggleLabel" Text="Show status on taskbar"/>
                        </Grid>
                        
                        <Grid ColumnDefinitions="Auto,*">
                            <ToggleSwitch IsChecked="{Binding Settings.HideSystemTrayIcon}" />
                            <TextBlock Grid.Column="1" Classes="ToggleLabel" Text="Hide system tray icon"/>
                        </Grid>
                        
                        <Grid ColumnDefinitions="Auto,*">
                            <ToggleSwitch IsChecked="{Binding Settings.ShowSystemTrayNotifications}" />
                            <TextBlock Grid.Column="1" Classes="ToggleLabel" Text="Show system tray notifications"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </TabItem>

            <TabItem Header="Schedules">
                <Border Classes="TabContent">
                    <Grid ColumnDefinitions="220,*" x:CompileBindings="False">
                        <!-- Left: schedule list + add/remove -->
                        <Grid Grid.Column="0" RowDefinitions="*,Auto" Margin="0,0,15,0">
                            <Border Grid.Row="0" BorderBrush="#333" BorderThickness="0,0,1,0" Padding="0,0,15,0">
                                <ListBox x:Name="SchedulesList" ItemsSource="{Binding Schedules}"
                                         SelectedItem="{Binding SelectedSchedule}"
                                         Background="Transparent" Foreground="White">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="5,3">
                                                <TextBlock Text="{Binding Action}" Foreground="White"/>
                                                <TextBlock Text="{Binding CronExpression}" Foreground="#888" FontSize="11"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>
                            <StackPanel Grid.Row="1" Margin="0,8,15,0" Spacing="6">
                                <ComboBox HorizontalAlignment="Stretch" ItemsSource="{Binding ScheduleTypeNames}"
                                          SelectedItem="{Binding SelectedScheduleTypeName}" Background="#222" Foreground="White"/>
                                <Grid ColumnDefinitions="*,*">
                                    <Button Grid.Column="0" Content="Add" Command="{Binding AddScheduleCommand}"
                                            Margin="0,0,4,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Background="#4582c4" Foreground="White"/>
                                    <Button Grid.Column="1" Content="Remove" Command="{Binding RemoveScheduleCommand}"
                                            Margin="4,0,0,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Background="#5a3030" Foreground="White"/>
                                </Grid>
                            </StackPanel>
                        </Grid>

                        <!-- Right: schedule editor -->
                        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel DataContext="{Binding SelectedSchedule}">
                                <TextBlock Text="Add a schedule to start or stop Move Mouse at set times." Foreground="#888"
                                           IsVisible="{Binding $parent[ScrollViewer].DataContext, Converter={x:Static ObjectConverters.IsNull}}"/>

                                <Grid Classes="Row" ColumnDefinitions="120,*">
                                    <TextBlock Classes="FieldLabel" Text="Action"/>
                                    <ComboBox Grid.Column="1" Classes="Field" ItemsSource="{Binding ScheduleActionValues}" SelectedItem="{Binding Action}"/>
                                </Grid>
                                <Grid Classes="Row" ColumnDefinitions="120,*">
                                    <TextBlock Classes="FieldLabel" Text="Enabled"/>
                                    <ToggleSwitch Grid.Column="1" IsChecked="{Binding IsEnabled}"/>
                                </Grid>

                                <Separator Background="#333" Margin="0,4,0,10"/>

                                <ContentControl Content="{Binding}">
                                    <ContentControl.DataTemplates>
                                        <DataTemplate DataType="schedules:SimpleSchedule">
                                            <StackPanel>
                                                <TextBlock Text="Days" Classes="FieldLabel" Margin="0,0,0,4"/>
                                                <WrapPanel Margin="0,0,0,10">
                                                    <CheckBox Classes="Day" Content="Mon" IsChecked="{Binding Monday}"/>
                                                    <CheckBox Classes="Day" Content="Tue" IsChecked="{Binding Tuesday}"/>
                                                    <CheckBox Classes="Day" Content="Wed" IsChecked="{Binding Wednesday}"/>
                                                    <CheckBox Classes="Day" Content="Thu" IsChecked="{Binding Thursday}"/>
                                                    <CheckBox Classes="Day" Content="Fri" IsChecked="{Binding Friday}"/>
                                                    <CheckBox Classes="Day" Content="Sat" IsChecked="{Binding Saturday}"/>
                                                    <CheckBox Classes="Day" Content="Sun" IsChecked="{Binding Sunday}"/>
                                                </WrapPanel>
                                                <Grid Classes="Row" ColumnDefinitions="120,*"><TextBlock Classes="FieldLabel" Text="Time"/><TextBox Grid.Column="1" Classes="Field" Width="120" HorizontalAlignment="Left" Text="{Binding TimeString}" Watermark="HH:MM:SS"/></Grid>
                                                <Grid Classes="Row" ColumnDefinitions="120,*"><TextBlock Classes="FieldLabel" Text="Random delay (s)"/><NumericUpDown Grid.Column="1" Value="{Binding Delay}" Minimum="0" Maximum="3600" FormatString="0" HorizontalAlignment="Left" Width="120"/></Grid>
                                            </StackPanel>
                                        </DataTemplate>
                                        <DataTemplate DataType="schedules:AdvancedSchedule">
                                            <StackPanel>
                                                <Grid Classes="Row" ColumnDefinitions="120,*"><TextBlock Classes="FieldLabel" Text="Cron"/><TextBox Grid.Column="1" Classes="Field" Text="{Binding Schedule}" Watermark="0 0 9 ? * MON-FRI"/></Grid>
                                                <TextBlock Text="Quartz cron format: sec min hour day-of-month month day-of-week." Foreground="#888" FontSize="11" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ContentControl.DataTemplates>
                                </ContentControl>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </TabItem>

            <TabItem Header="Blackouts">
                <Border Classes="TabContent">
                    <Grid ColumnDefinitions="220,*" x:CompileBindings="False">
                        <!-- Left: blackout list + add/remove -->
                        <Grid Grid.Column="0" RowDefinitions="*,Auto" Margin="0,0,15,0">
                            <Border Grid.Row="0" BorderBrush="#333" BorderThickness="0,0,1,0" Padding="0,0,15,0">
                                <ListBox x:Name="BlackoutsList" ItemsSource="{Binding Blackouts}"
                                         SelectedItem="{Binding SelectedBlackout}"
                                         Background="Transparent" Foreground="White">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="5,3">
                                                <TextBlock Text="{Binding TimeString}" Foreground="White"/>
                                                <TextBlock Text="{Binding DurationString, StringFormat='for {0}'}" Foreground="#888" FontSize="11"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>
                            <StackPanel Grid.Row="1" Margin="0,8,15,0" Spacing="6">
                                <Grid ColumnDefinitions="*,*">
                                    <Button Grid.Column="0" Content="Add" Command="{Binding AddBlackoutCommand}"
                                            Margin="0,0,4,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Background="#4582c4" Foreground="White"/>
                                    <Button Grid.Column="1" Content="Remove" Command="{Binding RemoveBlackoutCommand}"
                                            Margin="4,0,0,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Background="#5a3030" Foreground="White"/>
                                </Grid>
                            </StackPanel>
                        </Grid>

                        <!-- Right: blackout editor -->
                        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel DataContext="{Binding SelectedBlackout}">
                                <TextBlock Text="Add a blackout to pause Move Mouse during set times (e.g. overnight)." Foreground="#888"
                                           IsVisible="{Binding $parent[ScrollViewer].DataContext, Converter={x:Static ObjectConverters.IsNull}}"/>

                                <TextBlock Text="Days" Classes="FieldLabel" Margin="0,0,0,4"/>
                                <WrapPanel Margin="0,0,0,10">
                                    <CheckBox Classes="Day" Content="Mon" IsChecked="{Binding Monday}"/>
                                    <CheckBox Classes="Day" Content="Tue" IsChecked="{Binding Tuesday}"/>
                                    <CheckBox Classes="Day" Content="Wed" IsChecked="{Binding Wednesday}"/>
                                    <CheckBox Classes="Day" Content="Thu" IsChecked="{Binding Thursday}"/>
                                    <CheckBox Classes="Day" Content="Fri" IsChecked="{Binding Friday}"/>
                                    <CheckBox Classes="Day" Content="Sat" IsChecked="{Binding Saturday}"/>
                                    <CheckBox Classes="Day" Content="Sun" IsChecked="{Binding Sunday}"/>
                                </WrapPanel>
                                <Grid Classes="Row" ColumnDefinitions="120,*"><TextBlock Classes="FieldLabel" Text="Start time"/><TextBox Grid.Column="1" Classes="Field" Width="120" HorizontalAlignment="Left" Text="{Binding TimeString}" Watermark="HH:MM:SS"/></Grid>
                                <Grid Classes="Row" ColumnDefinitions="120,*"><TextBlock Classes="FieldLabel" Text="Duration"/><TextBox Grid.Column="1" Classes="Field" Width="120" HorizontalAlignment="Left" Text="{Binding DurationString}" Watermark="HH:MM:SS"/></Grid>
                                <Grid Classes="Row" ColumnDefinitions="120,*"><TextBlock Classes="FieldLabel" Text="Enabled"/><ToggleSwitch Grid.Column="1" IsChecked="{Binding IsEnabled}"/></Grid>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </TabItem>

            <TabItem Header="About">
                <Border Classes="TabContent">
                    <StackPanel Spacing="10" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Move Mouse for Linux" Foreground="White" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="Powered by .NET 8 + Avalonia UI" Foreground="White" HorizontalAlignment="Center"/>
                        <Button Content="View on GitHub" Click="OnGitHubClick" Background="#4582c4" Foreground="White" Margin="0,10,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </TabItem>
        </TabControl>
        
        <Border Grid.Row="1" Background="#11151c" Padding="0,0,20,0">
            <Button Content="Close" 
                    HorizontalAlignment="Right" 
                    VerticalAlignment="Center"
                    Width="80" HorizontalContentAlignment="Center"
                    Background="#333" Foreground="White"
                    Command="{Binding SaveSettingsCommand}"
                    Click="OnCloseClick" />
        </Border>
    </Grid>
</Window>

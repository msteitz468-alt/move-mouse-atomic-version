<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ellabi.ViewModels"
        x:Class="ellabi.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Move Mouse"
        Width="300" Height="300"
        WindowStartupLocation="CenterScreen"
        SystemDecorations="None"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        CanResize="False"
        PointerPressed="OnPointerPressed">

    <Window.Resources>
        <vm:StateToBrushConverter x:Key="StateToBrushConverter" />
    </Window.Resources>

    <Grid>
        <!-- The background glowing ring -->
        <Ellipse Stroke="{Binding State, Converter={StaticResource StateToBrushConverter}}" 
                 StrokeThickness="12" 
                 Width="240" Height="240"
                 Fill="#1E1E2E" />

        <!-- The rat mouse image -->
        <Image Source="avares://move-mouse/Assets/rat.png"
               Width="200" Height="200"
               Stretch="Uniform"
               VerticalAlignment="Center"
               HorizontalAlignment="Center"
               RenderOptions.BitmapInterpolationMode="HighQuality"/>
        
        <!-- Hover Instruction overlay (optional, but good for UX) -->
        <TextBlock Text="{Binding CountdownText}" 
                   Foreground="White" 
                   FontSize="22" 
                   FontWeight="Bold"
                   HorizontalAlignment="Center" 
                   VerticalAlignment="Bottom" 
                   Margin="0,0,0,40"
                   IsVisible="{Binding IsRunning}"/>

        <!-- Context menu (Right click) -->
        <Grid.ContextMenu>
            <ContextMenu>
                <MenuItem Header="Start" Command="{Binding StartCommand}" />
                <MenuItem Header="Pause" Command="{Binding PauseCommand}" />
                <MenuItem Header="Stop" Command="{Binding StopCommand}" />
                <Separator />
                <MenuItem Header="Settings" Click="OnSettingsClick" />
                <Separator />
                <MenuItem Header="Exit" Click="OnCloseContextClick" />
            </ContextMenu>
        </Grid.ContextMenu>
    </Grid>
</Window>
